    3 from ..prompts import RECOMMENDER_SYSTEM_PROMPT
    4 from langchain.schema import SystemMessage, HumanMessage
    5
    6 class TravelRecommender:
    7     def __init__(self):
    8         self.llm = get_llm()
    9
   10     def get_recommendations(self, budget, duration, interests, preferred_countries=None):
   11         # 1. Bazadan budjet bo'yicha birlamchi filtr qilish (ixtiyoriy)
   12         # destinations = Destination.objects.filter(price__lte=budget)
   13
   14         # 2. AI uchun so'rov tayyorlash
   15         user_query = f"Budjetim: ${budget}, Muddat: {duration} kun. Qiziqishlarim: {interests}. "
   16         if preferred_countries:
   17             user_query += f"Menga mana bu davlatlar yoqadi: {preferred_countries}"
   18
   19         messages = [
   20             SystemMessage(content=RECOMMENDER_SYSTEM_PROMPT),
   21             HumanMessage(content=user_query)
   22         ]
   23
   24         response = self.llm.invoke(messages)
   25         return response.content

