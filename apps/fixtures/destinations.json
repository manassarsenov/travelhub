      "slug": "admission-to-the-london-eye",
      "updated_at": "2026-03-09T21:38:34.505Z",
      "created_at": "2026-05-11T11:14:39.751Z",
      "city": 1,
      "country": 80,
      "name": "Admission to the London Eye",
      "short_description": "<p>Experience the magic of London from 135 meters above the ground. Enjoy a 30-minute flight with breathtaking 360-degree views of the city's most iconic landmarks.</p>",
      "description": "<p>Step inside one of the 32 high-tech glass pods and prepare for an unforgettable 30-minute journey. As the London Eye slowly rotates, the city unfolds beneath you in all its glory. From the historic majesty of Big Ben and the Houses of Parliament to the modern silhouette of the Shard, you'll see London like never before.</p><p>Whether you're visiting for the first time or the fiftieth, the views from the world's tallest cantilevered observation wheel are always mesmerizing. Your experience also includes entry to the London Eye 4D Cinema, where you'll feel the wind in your hair and the mist on your face in a spectacular multi-sensory film.</p>",
      "location": "London,England",
      "latitude": "0.00000400000000000",
      "longitude": "0.00000500000000000",
      "price": 25,
      "price_label": "person",
      "discount_percentage": 0,
      "hotels_count": 155,
      "has_flights": true,
      "restaurants_count": 0,
      "is_flash_sale": false,
      "flash_sale_end": null,
      "trip_type": "adventure",
      "duration": "weekend",
      "season": "Summer",
      "visible_reviews_count": 11,
      "is_free_cancellation": true,
      "free_cancellation_hours": 24,
      "is_popular": false,
      "is_trending": false,
      "is_featured": true,
      "featured_badge": "#1 Best seller in London",
      "why_visit": "<ul>\n<li><i class='fas fa-eye'></i> <strong>Unrivaled Panoramic Views:</strong> Experience breathtaking 360-degree views of London's skyline from 135 meters high.</li>\n<li><i class='fas fa-landmark'></i> <strong>Spot Iconic Landmarks:</strong> Get a bird's-eye view of Big Ben, the Houses of Parliament, and Buckingham Palace.</li>\n<li><i class='fas fa-camera'></i> <strong>Perfect Photo Opportunities:</strong> Capture stunning photos of the city from every angle in a spacious, climate-controlled pod.</li>\n<li><i class='fas fa-film'></i> <strong>4D Cinema Experience:</strong> Enjoy a multi-sensory short film that brings London to life with wind, bubbles, and scents.</li>\n</ul>",
      "whats_included": "<ul>\n<li><i class='fas fa-check'></i> Standard Entry Ticket for one rotation (approx. 30 mins)</li>\n<li><i class='fas fa-check'></i> Entrance to the immersive 4D Cinema Experience</li>\n<li><i class='fas fa-check'></i> Access to the London Eye Guide app for interactive info</li>\n<li><i class='fas fa-check'></i> Samsung Galaxy Tab interactive guides inside the pod</li>\n</ul>",
      "restrictions": "<ul>\n<li>Large luggage and suitcases are not permitted (storage available nearby).</li>\n<li>Children under 15 must be accompanied by an adult (18+).</li>\n<li>All guests must pass through a security scan before boarding.</li>\n<li>Last rotation is 30 minutes before the closing time.</li>\n</ul>",
      "additional_info": "",
      "package_type": "business",
